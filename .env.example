# =============================================================================
# Duevy Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# -----------------------------------------------------------------------------
# Database — Supabase PostgreSQL
# Get these from your Supabase project > Settings > Database
# Use the "Connection string" (Transaction pooler recommended for serverless,
# Session pooler or direct for a long-running Node process).
# NOTE: URL-encode special characters in the password (/ & + , = %2F %26 %2B %2C).
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT].supabase.co:5432/postgres"

# For migrations, use the direct connection (not the pooler):
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@[YOUR-PROJECT].supabase.co:5432/postgres"

# -----------------------------------------------------------------------------
# JWT
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET="change-me-access-secret-min-64-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-64-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# -----------------------------------------------------------------------------
# Redis (Docker Compose default)
# -----------------------------------------------------------------------------
REDIS_URL="redis://localhost:6379"

# -----------------------------------------------------------------------------
# Google Sign-In (§2.3)
# OAuth 2.0 Client ID from https://console.cloud.google.com/apis/credentials
# Optional — while unset, POST /auth/google returns 501 NOT_IMPLEMENTED.
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID="xxxxxxxxxxxx.apps.googleusercontent.com"

# -----------------------------------------------------------------------------
# Resend (email)
# Get your API key from https://resend.com/api-keys
# -----------------------------------------------------------------------------
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_FROM_EMAIL="Duevy <no-reply@duevy.app>"

# -----------------------------------------------------------------------------
# Payment gateway — which processor is live. Both are fully implemented
# (src/lib/monnify.ts, src/lib/paystack.ts); this just picks one. See
# src/lib/paymentGateway.ts. Only the active gateway's keys below are required.
# -----------------------------------------------------------------------------
PAYMENT_GATEWAY=paystack 

PAYSTACK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
PAYSTACK_BASE_URL="https://api.paystack.co"
# Webhook signature validation reuses PAYSTACK_SECRET_KEY — no separate secret needed.

# Monnify (payment provider) — inactive while PAYMENT_GATEWAY=paystack, kept
# working so switching back is a one-line env change. Sandbox: https://sandbox.monnify.com/
MONNIFY_API_KEY="MK_TEST_xxxxxxxxxxxxxxxxxx"
MONNIFY_SECRET_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
MONNIFY_BASE_URL="https://sandbox.monnify.com"
MONNIFY_CONTRACT_CODE="xxxxxxxx"

# Webhook signature validation — your Monnify client secret (same as secret key above)
MONNIFY_WEBHOOK_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Wallet account rep payouts are disbursed from (Monnify disbursement wallet).
# Optional — while unset, payout requests are recorded but no transfer is sent (§10.3 stays manual).
MONNIFY_DISBURSEMENT_SOURCE_ACCOUNT="xxxxxxxxxx"

# -----------------------------------------------------------------------------
# App URLs
# -----------------------------------------------------------------------------
APP_BASE_URL="http://localhost:3000"
FRONTEND_URL="http://localhost:3001"

# Allowed CORS origins (comma-separated)
CORS_ORIGINS="http://localhost:3001,http://localhost:3000"

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
BCRYPT_ROUNDS=12

# Cookie settings
COOKIE_SECURE=false          # Set to true in production (HTTPS)
COOKIE_SAME_SITE=lax         # lax | strict | none

# -----------------------------------------------------------------------------
# Duey (AI chat assistant) — classification backend. See src/lib/llm/.
# 'ollama'  — local/dev Ollama instance (Gemma or any model it serves)
# 'gemini'  — Google's Gemini API, called natively (no OpenAI-compat shim)
# 'hosted'  — any other OpenAI-chat-completions-compatible endpoint
#             (self-hosted vLLM box, etc.)
# -----------------------------------------------------------------------------
LLM_PROVIDER=ollama          # ollama | gemini | hosted
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="gemma2:9b"

# Only used when LLM_PROVIDER=gemini. Get a key from https://aistudio.google.com/apikey
GEMINI_BASE_URL="https://generativelanguage.googleapis.com"
GEMINI_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
GEMINI_MODEL="gemini-2.0-flash"

# Only used when LLM_PROVIDER=hosted (generic OpenAI-compatible endpoints only —
# NOT for Gemini; use the GEMINI_* vars above for that instead)
LLM_HOSTED_BASE_URL="https://your-openai-compatible-endpoint.example.com/v1"
LLM_HOSTED_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
LLM_HOSTED_MODEL="your-model-name"
LLM_TIMEOUT_MS=8000
